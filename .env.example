# Copy to .env and set your local path
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/your-service-account.json
DEEPSEEK_API_KEY=your-deepseek-api-key
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id
GOOGLE_SHEETS_URL=https://docs.google.com/spreadsheets/d/your-spreadsheet-id/edit

# Scraper — review snippets for personalized site copy (optional)
# MAX_REVIEW_SNIPPETS=8
# REVIEW_SCRAPE_TIMEOUT_SEC=12
# SKIP_REVIEW_SCRAPE=0
